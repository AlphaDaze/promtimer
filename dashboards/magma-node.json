{
    "_base": "dashboard",
    "title": "Magma - Node",
    "templating": {
        "list": [
            {
                "hide": 0,
                "includeAll": false,
                "label": null,
                "multi": false,
                "name": "node",
                "options": [],
                "query": "prometheus",
                "refresh": 1,
                "regex": "",
                "skipUrlSync": false,
                "type": "datasource"
            }
        ]
    },
    "_panels": [
        {
            "_base": "panel",
            "title": "Gets rate",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (rate(kv_ep_magma_gets[1m]))",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Sets rate",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (rate(kv_ep_magma_sets[1m]))",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Inserts rate",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (rate(kv_ep_magma_inserts[1m]))",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Memory",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "kv_ep_magma_total_mem_used_bytes",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Thread pool CPU",
            "gridPos": {
              "h": 9
            },
            "_targets": [
              {
                "datasource": "{data-source:name}",
                "expr": "sum by (thread_pool) (rate(kv_thread_cpu_usage_seconds[6m]))",
                "legendFormat": "{{label_name}}",
                "_base": "target"
              }
            ]
          },
          {
            "_base": "panel",
            "title": "Disk IO",
            "type": "row"
          },
          {
            "_base": "panel",
            "title": "Write bytes rate",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (rate(kv_ep_magma_write_bytes_bytes[1m]))",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Write bytes",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_write_bytes_bytes)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Bytes incoming rate",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (rate(kv_ep_magma_bytes_incoming_bytes[1m]))",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Bytes incoming",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_bytes_incoming_bytes)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Read bytes rate",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (rate(kv_ep_magma_read_bytes_bytes[1m]))",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Read bytes",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_read_bytes_bytes)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Bytes outgoing rate",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (rate(kv_ep_magma_bytes_outgoing_bytes[1m]))",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Bytes outgoing",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_bytes_outgoing_bytes)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Size",
            "type": "row"
          },
        {
            "_base": "panel",
            "title": "Total disk usage",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_total_disk_usage_bytes)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Compression",
            "gridPos": {
                "h": 9
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent"
                }
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "avg by (bucket) (kv_ep_magma_data_blocks_space_reduction_estimate_pct_ratio*100)",
                    "legendFormat": "{{bucket}} block compression savings %",
                    "_base": "target"
                },
                {
                    "datasource": "{data-source:name}",
                    "expr": "(1 - ((sum by (bucket) (kv_ep_total_compressed_value_size_bytes) / (sum by (bucket) (kv_ep_total_decompressed_value_size_bytes) > 0)) or (sum by (bucket) (kv_ep_total_compressed_value_size_bytes) * 0 + 1)) * (sum by (bucket) (kv_ep_magma_data_blocks_compressed_size) / sum by (bucket) (kv_ep_magma_data_blocks_uncompressed_size))) * 100",
                    "legendFormat": "{{bucket}} total compression savings %",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "Fragmentation%",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_fragmentation_ratio*100)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "History",
            "type": "row"
          },
          {
            "_base": "panel",
            "title": "History bytes evicted due to size",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_history_size_evicted_bytes)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        },
        {
            "_base": "panel",
            "title": "History bytes evicted due to time",
            "gridPos": {
                "h": 9
            },
            "_targets": [
                {
                    "datasource": "{data-source:name}",
                    "expr": "sum by (bucket) (kv_ep_magma_history_time_evicted_bytes)",
                    "legendFormat": "{{bucket}}",
                    "_base": "target"
                }
            ]
        }
    ]
}
